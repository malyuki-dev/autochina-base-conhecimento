// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A URL foi removida daqui para seguir o novo padrão do Prisma 7
}

enum ResourceType {
  BOOK
  VIDEO
  TEXT
}

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String?      
  type        ResourceType
  url         String       
  category    String       
  tags        String[]     
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}